{
  "name": "streamloyal",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @streamloyal/db generate",
    "db:push": "pnpm --filter @streamloyal/db push",
    "db:migrate": "pnpm --filter @streamloyal/db migrate"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
